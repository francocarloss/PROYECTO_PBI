	column RAZON_SOCIAL
		dataType: string
		lineageTag: 90be99c2-ac72-429e-9ab3-c57553c8a0cc
		summarizeBy: none
		sourceColumn: RAZON_SOCIAL

		annotation SummarizationSetBy = Automatic

	partition Procedimientos = m
		mode: import
		source = ```
				let
				    Source =
				        Oracle.Database(
				            DBConnection,
				            [
				                Query="
				                SELECT 
				                    cp2.ID_PAYING AS LIQUIDACION,
				                    cc.ID_CLAIMS AS RECLAMO,
				                    TO_CHAR(cp2.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_LIQUIDACION,
				                    TO_CHAR(cp2.REPORTING_DATE, 'dd/MM/yyyy') AS FECHA_RECEPCION,
				                    TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_INCURRIDO,
				                    GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C') AS ASEGURADORA,
				                    GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I') AS CONTRATANTE,
				                    pa.LICENSE AS NUMERO_CARNET,
				                    GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A') AS NOMBRE_PACIENTE,
				                    pat.DES_ASSURED_TYPE AS PARENTESCO,
				                    cpd.INVOICE_NUMBER AS NUMERO_FACTURA,
				                    TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy') AS FECHA_FACTURA,
				                    cp.ID_PRESCRIPTION AS ORDEN,
				                    cpdp.ID_AUTHORIZATION AS NUMERO_AUTORIZACION,
				                    cp.ID_CLAIMS AS NUMERO_VERIFICACION,
				                    TO_CHAR(ca2.AUTHORIZATION_DATE, 'dd/MM/yyyy') AS FECHA_AUTORIZACION,
				                    GEN_SUPPLIER_NAME_FUNC(cp.ID_DOCTOR) AS MEDICO_TRATANTE,
				                    GEN_SUPPLIER_SPECIALTY_FUNC(cp.ID_DOCTOR) AS ESPECIALIDAD,
				                    cpdp.ID_CLINIC_PROCESS AS CODIGO_PROCEDIMIENTO,
				                    CASE 
				                        WHEN (cpdp.ID_CLINIC_PROCESS IS NOT NULL) THEN
				                            UPPER(TRIM(ccp.DES_CLINIC_PROCESS))
				                        ELSE 
				                            'SIN PROCEDIMIENTO'
				                    END AS NOMBRE_EXAMEN,
				                    1 AS CANTIDAD,
				                    POL_ASSURED_MAIN_BY_ID_FUNC(pa.ID_ASSURED) AS ASEGURADO_TITULAR,
				                    cd.ID_DIAGNOSIS AS CODIGO_DIAGNOSTICO,
				                    cd.DES_DIAGNOSIS AS NOMBRE_DIAGNOSTICO_PRINCIPAL,
				                    UPPER(REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' ')) AS DIAGNOSTICO_SECUNDARIO,
				                    pp.ID_POLICY AS POLIZA,
				                    pa.ID_CERTIFICATE AS CERTIFICADO,
				                    CASE
				                        WHEN cp.IS_OUTPATIENT = 1 THEN 'PROCEDIMIENTO EN CLÍNICA' 
				                        ELSE '' 
				                    END AS TIPO_ORDEN,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') AS VALOR_APROVADO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_NO_APROVADO') AS VALOR_NO_APROVADO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') AS VALOR_DEDUCIBLE,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') AS VALOR_COASEGURO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO') AS VALOR_COPAGO,
				                    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'))) AS COBRO_ASEGURADORA,
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'C'), 'SIN PROVEEDOR') AS NOMBRE_PROVEEDOR,
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'R'), 'SIN PROVEEDOR') AS RAZON_SOCIAL
				                FROM CLA_PRESCRIPTION cp
				                JOIN CLA_CLAIMS cc ON (cp.ID_CLAIM_DISPATCHED = cc.ID_CLAIMS)
				                JOIN POL_POLICY pp ON (cc.ID_POLICY = pp.ID_POLICY AND cc.ID_INSURERS = cc.ID_INSURERS)
				                JOIN GEN_INSURERS gi ON (cc.ID_INSURERS = gi.ID_INSURERS)
				                JOIN GEN_CUSTOMER gc ON (pp.ID_CUSTOMER = gc.ID_CUSTOMER)
				                JOIN CLA_PAYING cp2 ON (cc.ID_CLAIMS = cp2.ID_CLAIMS)
				                JOIN CLA_PAYING_DT cpd ON (cp2.ID_PAYING = cpd.ID_PAYING)
				                JOIN POL_ASSURED pa ON (cp.ID_ASSURED = pa.ID_ASSURED)
				                JOIN POL_ASSURED_TYPE pat ON (pa.ID_ASSURED_TYPE = pat.ID_ASSURED_TYPE)
				                JOIN CLA_DIAGNOSIS cd ON (cc.ID_DIAGNOSIS = cd.ID_DIAGNOSIS)
				                LEFT JOIN CLA_PRESCRIPTION_DT_PROCESS cpdp ON (cp.ID_PRESCRIPTION = cpdp.ID_PRESCRIPTION)
				                LEFT JOIN CLA_CLINIC_PROCESS ccp ON (cpdp.ID_CLINIC_PROCESS = ccp.ID_CLINIC_PROCESS)
				                LEFT JOIN CLA_AUTHORIZATIONS ca2 ON (cpdp.ID_AUTHORIZATION = ca2.ID_AUTHORIZATION)
				                WHERE 1 = 1
				                AND cc.ID_INSURERS IN (41, 42, 44, 46, 48, 49, 51, 52, 53, 55, 56)
				                AND TRUNC(cc.DATE_CREATED) BETWEEN TO_DATE('01/01/2025', 'dd/MM/yyyy') AND TRUNC(SYSDATE)
				                AND cp.IS_OUTPATIENT = 1
				                GROUP BY
				                    cp2.ID_PAYING,
				                    cc.ID_CLAIMS,
				                    TO_CHAR(cp2.DATE_CREATED, 'dd/MM/yyyy'),
				                    TO_CHAR(cp2.REPORTING_DATE, 'dd/MM/yyyy'),
				                    TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy'),
				                    GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C'),
				                    GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I'),
				                    pa.LICENSE,
				                    GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A'),
				                    pat.DES_ASSURED_TYPE,
				                    cpd.INVOICE_NUMBER,
				                    TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy'),
				                    cp.ID_PRESCRIPTION,
				                    cpdp.ID_AUTHORIZATION,
				                    cp.ID_CLAIMS,
				                    TO_CHAR(ca2.AUTHORIZATION_DATE, 'dd/MM/yyyy'),
				                    GEN_SUPPLIER_NAME_FUNC(cp.ID_DOCTOR),
				                    GEN_SUPPLIER_SPECIALTY_FUNC(cp.ID_DOCTOR),
				                    cpdp.ID_CLINIC_PROCESS,
				                    ccp.DES_CLINIC_PROCESS,
				                    1,
				                    POL_ASSURED_MAIN_BY_ID_FUNC(pa.ID_ASSURED),
				                    cd.ID_DIAGNOSIS,
				                    cd.DES_DIAGNOSIS,
				                    REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' '),
				                    pp.ID_POLICY,
				                    pa.ID_CERTIFICATE,
				                    CASE
				                        WHEN cp.IS_OUTPATIENT = 1 THEN 'PROCEDIMIENTO EN CLÍNICA'
				                        ELSE '' 
				                    END,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_NO_APROVADO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'),
				                    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'))),
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'C'), 'SIN PROVEEDOR'),
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'R'), 'SIN PROVEEDOR')
				                ORDER BY 1 DESC
				                "
				            ]
				        )
				in
				    Source
				```

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

