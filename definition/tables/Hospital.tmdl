	column RAZON_SOCIAL
		dataType: string
		lineageTag: db499fae-1a74-4f1b-bb35-521acd88a3f6
		summarizeBy: none
		sourceColumn: RAZON_SOCIAL

		annotation SummarizationSetBy = Automatic

	partition Hospital = m
		mode: import
		source = ```
				let
				    Source =
				        Oracle.Database(
				            DBConnection,
				            [
				                Query="
				                SELECT 
				                    cp.ID_PAYING AS LIQUIDACION,
				                    cc.ID_CLAIMS AS RECLAMO,
				                    TO_CHAR(cp.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_LIQUIDACION,
				                    TO_CHAR(cp.REPORTING_DATE, 'dd/MM/yyyy') AS FECHA_RECEPCION,
				                    TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_INCURRIDO,
				                    GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C') AS ASEGURADORA,
				                    GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I') AS CONTRATANTE,
				                    pa.LICENSE AS NUMERO_CARNET,
				                    GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A') AS NOMBRE_PACIENTE,
				                    UPPER(pat.DES_ASSURED_TYPE) AS PARENTESCO,
				                    cpd.INVOICE_NUMBER AS NUMERO_FACTURA,
				                    TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy') AS FECHA_FACTURA,
				                    ca.ID_AUTHORIZATION AS NUMERO_AUTORIZACION,
				                    TO_CHAR(ca.AUTHORIZATION_DATE, 'dd/MM/yyyy') AS FECHA_AUTORIZACION,
				                    GEN_SUPPLIER_NAME_FUNC(ch.ID_HOSPITAL) AS HOSPITAL,
				                    POL_ASSURED_TYPE_FUNC(pa.ID_CERTIFICATE) AS ASEGURADO_TITULAR,
				                    cd.ID_DIAGNOSIS AS CODIGO_DIAGNOSTICO,
				                    cd.DES_DIAGNOSIS AS NOMBRE_DIAGNOSTICO_PRINCIPAL,
				                    UPPER(REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' ')) AS DIAGNOSTICO_SECUNDARIO,
				                    pp.ID_POLICY AS POLIZA,
				                    pa.ID_CERTIFICATE AS CERTIFICADO,
				                    'HOSPITAL' AS TIPO_ORDEN,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_APROVADO') AS VALOR_APROVADO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_NO_APROVADO') AS VALOR_NO_APROVADO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'DEDUCIBLE') AS VALOR_DEDUCIBLE,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COASEGURO') AS VALOR_COASEGURO,
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COPAGO') AS VALOR_COPAGO,
				                    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COPAGO'))) AS COBRO_ASEGURADORA,
				                    UPPER(REPLACE(REPLACE(ca.COMMENTS, CHR(10), ' '), CHR(13), ' ')) AS OBSERVACIONES,
				                    NVL(TO_CHAR(ch.ENTRY_DATE_HOSP, 'dd/MM/yyyy'), 'SIN FECHA') AS FECHA_INGRESO,
				                    NVL(TO_CHAR(ch.EXIT_DATE_HOSP, 'dd/MM/yyyy'), 'SIN FECHA') AS FECHA_EGRESO,
				                    NVL(ch.DAYS_HOSPITALIZATION, 0) AS DIAS_HOSPITALIZACION,
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(ch.ID_HOSPITAL, 'C'), 'SIN PROVEEDOR') AS NOMBRE_PROVEEDOR,
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(ch.ID_HOSPITAL, 'R'), 'SIN PROVEEDOR') AS RAZON_SOCIAL
				                FROM CLA_CLAIMS cc 
				                JOIN CLA_HOSPITAL ch ON (cc.ID_CLAIMS = ch.ID_CLAIMS)
				                JOIN CLA_PAYING cp ON (cc.ID_CLAIMS = cp.ID_CLAIMS)
				                JOIN CLA_PAYING_DT cpd ON (cp.ID_PAYING = cpd.ID_PAYING)
				                JOIN POL_POLICY pp ON (cc.ID_POLICY = pp.ID_POLICY AND cc.ID_INSURERS = cc.ID_INSURERS)
				                JOIN GEN_INSURERS gi ON (pp.ID_INSURERS = gi.ID_INSURERS)
				                JOIN GEN_CUSTOMER gc ON (pp.ID_CUSTOMER = gc.ID_CUSTOMER)
				                JOIN POL_ASSURED pa ON (cc.ID_ASSURED = pa.ID_ASSURED)
				                JOIN POL_ASSURED_TYPE pat ON (pa.ID_ASSURED_TYPE = pat.ID_ASSURED_TYPE)
				                JOIN CLA_DIAGNOSIS cd ON (cc.ID_DIAGNOSIS = cd.ID_DIAGNOSIS)
				                LEFT JOIN CLA_AUTHORIZATIONS ca ON (ch.ID_AUTHORIZATION = ca.ID_AUTHORIZATION)
				                WHERE 1 = 1
				                AND cc.ID_INSURERS IN (41, 42, 44, 46, 48, 49, 51, 52, 53, 55, 56)
				                AND TRUNC(cc.DATE_CREATED) BETWEEN TO_DATE('01/01/2025', 'dd/MM/yyyy') AND TRUNC(SYSDATE)
				                GROUP BY 
				                    cp.ID_PAYING,
				                    cc.ID_CLAIMS,
				                    TO_CHAR(cp.DATE_CREATED, 'dd/MM/yyyy'),
				                    TO_CHAR(cp.REPORTING_DATE, 'dd/MM/yyyy'),
				                    TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy'),
				                    GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C'),
				                    GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I'),
				                    pa.LICENSE,
				                    GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A'),
				                    UPPER(pat.DES_ASSURED_TYPE),
				                    cpd.INVOICE_NUMBER,
				                    TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy'),
				                    ca.ID_AUTHORIZATION,
				                    TO_CHAR(ca.AUTHORIZATION_DATE, 'dd/MM/yyyy'),
				                    GEN_SUPPLIER_NAME_FUNC(ch.ID_HOSPITAL),
				                    POL_ASSURED_TYPE_FUNC(pa.ID_CERTIFICATE),
				                    cd.ID_DIAGNOSIS,
				                    cd.DES_DIAGNOSIS,
				                    UPPER(REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' ')),
				                    pp.ID_POLICY,
				                    pa.ID_CERTIFICATE,
				                    'HOSPITAL',
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_APROVADO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_NO_APROVADO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'DEDUCIBLE'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COASEGURO'),
				                    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COPAGO'),
				                    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp.ID_PAYING, 'COPAGO'))),
				                    UPPER(REPLACE(REPLACE(ca.COMMENTS, CHR(10), ' '), CHR(13), ' ')),
				                    NVL(TO_CHAR(ch.ENTRY_DATE_HOSP, 'dd/MM/yyyy'), 'SIN FECHA'),
				                    NVL(TO_CHAR(ch.EXIT_DATE_HOSP, 'dd/MM/yyyy'), 'SIN FECHA'),
				                    NVL(ch.DAYS_HOSPITALIZATION, 0),
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(ch.ID_HOSPITAL, 'C'), 'SIN PROVEEDOR'),
				                    NVL(GEN_SUPPLIER_NAME2_FUNC(ch.ID_HOSPITAL, 'R'), 'SIN PROVEEDOR')
				                ORDER BY 1 DESC
				                "
				            ]
				        )
				in
				    Source
				```

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

