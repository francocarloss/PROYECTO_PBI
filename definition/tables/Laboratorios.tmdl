	partition Laboratorios = m
		mode: import
		source =
				let
				    Origen = Oracle.Database(DBConnection, [HierarchicalNavigation=true, Query="SELECT #(lf)#(tab)cp2.ID_PAYING AS LIQUIDACION,#(lf)#(tab)cc.ID_CLAIMS AS RECLAMO,#(lf)#(tab)TO_CHAR(cp2.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_LIQUIDACION,#(lf)#(tab)TO_CHAR(cp2.REPORTING_DATE, 'dd/MM/yyyy') AS FECHA_RECEPCION,#(lf)#(tab)TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy') AS FECHA_INCURRIDO,#(lf)#(tab)GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C') AS ASEGURADORA,#(lf)#(tab)GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I') AS CONTRATANTE,#(lf)#(tab)pa.LICENSE AS NUMERO_CARNET,#(lf)#(tab)GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A') AS NOMBRE_PACIENTE,#(lf)#(tab)pat.DES_ASSURED_TYPE AS PARENTESCO,#(lf)#(tab)cpd.INVOICE_NUMBER AS NUMERO_FACTURA,#(lf)#(tab)TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy') AS FECHA_FACTURA,#(lf)#(tab)cp.ID_PRESCRIPTION AS ORDEN,#(lf)#(tab)cld.ID_AUTHORIZATION AS NUMERO_AUTORIZACION,#(lf)#(tab)cp.ID_CLAIMS AS NUMERO_VERIFICACION,#(lf)#(tab)TO_CHAR(ca2.AUTHORIZATION_DATE, 'dd/MM/yyyy') AS FECHA_AUTORIZACION,#(lf)#(tab)GEN_SUPPLIER_NAME_FUNC(cp.ID_DOCTOR) AS MEDICO_TRATANTE,#(lf)#(tab)GEN_SUPPLIER_SPECIALTY_FUNC(cp.ID_DOCTOR) AS ESPECIALIDAD,#(lf)#(tab)cld.ID_TEST AS CODIGO_EXAMEN,#(lf)#(tab)CASE #(lf)#(tab)#(tab)WHEN (cld.ID_TEST IS NOT NULL) THEN#(lf)#(tab)#(tab)#(tab)UPPER(TRIM(clt.TEST))#(lf)#(tab)#(tab)ELSE #(lf)#(tab)#(tab)#(tab)'SIN EXÁMEN'#(lf)#(tab)END AS NOMBRE_EXAMEN,#(lf)#(tab)1 AS CANTIDAD,#(lf)#(tab)POL_ASSURED_MAIN_BY_ID_FUNC(pa.ID_ASSURED) AS ASEGURADO_TITULAR,#(lf)#(tab)cd.ID_DIAGNOSIS AS CODIGO_DIAGNOSTICO,#(lf)#(tab)cd.DES_DIAGNOSIS AS NOMBRE_DIAGNOSTICO_PRINCIPAL,#(lf)#(tab)UPPER(REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' ')) AS DIAGNOSTICO_SECUNDARIO,#(lf)#(tab)pp.ID_POLICY AS POLIZA,#(lf)#(tab)pa.ID_CERTIFICATE AS CERTIFICADO,#(lf)#(tab)CASE#(lf)#(tab)   WHEN cp.IS_SRAY = 1 THEN 'RAYOS X'#(lf)#(tab)   WHEN cp.IS_LAB = 1 THEN 'LABORATORIO'#(lf)#(tab)   WHEN cp.IS_CYTOLOGIE = 1 THEN 'CITOLOGIA'#(lf)#(tab)   WHEN cp.IS_LAB_NO_AUTH = 1 THEN 'EXAMEN ESPECIAL'#(lf)#(tab)   WHEN cp.IS_OTHER_SERVICES = 1 THEN 'OTRO SERVICIO'#(lf)#(tab)   ELSE '' #(lf)#(tab)END AS TIPO_ORDEN,#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') AS VALOR_APROVADO,#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_NO_APROVADO') AS VALOR_NO_APROVADO,#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') AS VALOR_DEDUCIBLE,#(lf)    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') AS VALOR_COASEGURO,#(lf)    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO') AS VALOR_COPAGO,#(lf)    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'))) AS COBRO_ASEGURADORA,#(lf)    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'C'), 'SIN PROVEEDOR') AS NOMBRE_PROVEEDOR,#(lf)    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'R'), 'SIN PROVEEDOR') AS RAZON_SOCIAL#(lf)FROM CLA_PRESCRIPTION cp#(lf)JOIN CLA_CLAIMS cc ON (cp.ID_CLAIM_DISPATCHED = cc.ID_CLAIMS)#(lf)JOIN POL_POLICY pp ON (cc.ID_POLICY = pp.ID_POLICY AND cc.ID_INSURERS = cc.ID_INSURERS)#(lf)JOIN GEN_INSURERS gi ON (cc.ID_INSURERS = gi.ID_INSURERS)#(lf)JOIN GEN_CUSTOMER gc ON (pp.ID_CUSTOMER = gc.ID_CUSTOMER)#(lf)JOIN CLA_PAYING cp2 ON (cc.ID_CLAIMS = cp2.ID_CLAIMS)#(lf)JOIN CLA_PAYING_DT cpd ON (cp2.ID_PAYING = cpd.ID_PAYING)#(lf)JOIN POL_ASSURED pa ON (cp.ID_ASSURED = pa.ID_ASSURED)#(lf)JOIN POL_ASSURED_TYPE pat ON (pa.ID_ASSURED_TYPE = pat.ID_ASSURED_TYPE)#(lf)JOIN CLA_DIAGNOSIS cd ON (cc.ID_DIAGNOSIS = cd.ID_DIAGNOSIS)#(lf)LEFT JOIN CLA_LABORATORY cl ON (cc.ID_CLAIMS = cl.ID_CLAIMS)#(lf)#(tab)JOIN CLA_LABORATORY_DT cld ON (cl.ID_CLA_LAB = cld.ID_CLA_LAB)#(lf)LEFT JOIN CLA_AUTHORIZATIONS ca2 ON (cld.ID_AUTHORIZATION = ca2.ID_AUTHORIZATION)#(lf)LEFT JOIN CLA_LABORATORY_TEST clt ON (cld.ID_TEST = clt.ID_TEST)#(lf)WHERE 1 = 1#(lf)AND cc.ID_INSURERS IN (41, 42, 44, 46, 48, 49, 51, 52, 53, 55, 56)#(lf)AND TRUNC(cc.DATE_CREATED) BETWEEN TO_DATE('01/01/2025', 'dd/MM/yyyy') AND TRUNC(SYSDATE)#(lf)AND (cp.IS_SRAY = 1 OR cp.IS_LAB = 1 OR cp.IS_CYTOLOGIE = 1 OR cp.IS_LAB_NO_AUTH = 1 OR cp.IS_OTHER_SERVICES = 1)#(lf)GROUP BY#(lf)#(tab)cp2.ID_PAYING,#(lf)#(tab)cc.ID_CLAIMS,#(lf)#(tab)TO_CHAR(cp2.DATE_CREATED, 'dd/MM/yyyy'),#(lf)#(tab)TO_CHAR(cp2.REPORTING_DATE, 'dd/MM/yyyy'),#(lf)#(tab)TO_CHAR(cc.DATE_CREATED, 'dd/MM/yyyy'),#(lf)#(tab)GEN_PERSON_NAME_FUNC(gi.ID_PERSON,'C'),#(lf)#(tab)GEN_PERSON_NAME_FUNC(gc.ID_PERSON,'I'),#(lf)#(tab)pa.LICENSE,#(lf)#(tab)GEN_PERSON_NAME_FUNC(pa.ID_PERSON,'A'),#(lf)#(tab)pat.DES_ASSURED_TYPE,#(lf)#(tab)cpd.INVOICE_NUMBER,#(lf)#(tab)TO_CHAR(cpd.INVOICE_DATE, 'dd/MM/yyyy'),#(lf)#(tab)cp.ID_PRESCRIPTION,#(lf)#(tab)cld.ID_AUTHORIZATION,#(lf)#(tab)cp.ID_CLAIMS,#(lf)#(tab)TO_CHAR(ca2.AUTHORIZATION_DATE, 'dd/MM/yyyy'),#(lf)#(tab)GEN_SUPPLIER_NAME_FUNC(cp.ID_DOCTOR),#(lf)#(tab)GEN_SUPPLIER_SPECIALTY_FUNC(cp.ID_DOCTOR),#(lf)#(tab)cld.ID_TEST,#(lf)#(tab)clt.TEST,#(lf)#(tab)1,#(lf)#(tab)POL_ASSURED_MAIN_BY_ID_FUNC(pa.ID_ASSURED),#(lf)#(tab)cd.ID_DIAGNOSIS,#(lf)#(tab)cd.DES_DIAGNOSIS,#(lf)#(tab)REPLACE(REPLACE(cc.SPECIFIC_DIAGNOSIS, CHR(10), ' '), CHR(13), ' '),#(lf)#(tab)pp.ID_POLICY,#(lf)#(tab)pa.ID_CERTIFICATE,#(lf)#(tab)CASE#(lf)#(tab)   WHEN cp.IS_SRAY = 1 THEN 'RAYOS X'#(lf)#(tab)   WHEN cp.IS_LAB = 1 THEN 'LABORATORIO'#(lf)#(tab)   WHEN cp.IS_CYTOLOGIE = 1 THEN 'CITOLOGIA'#(lf)#(tab)   WHEN cp.IS_LAB_NO_AUTH = 1 THEN 'EXAMEN ESPECIAL'#(lf)#(tab)   WHEN cp.IS_OTHER_SERVICES = 1 THEN 'OTRO SERVICIO'#(lf)#(tab)   ELSE '' #(lf)#(tab)END,#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO'),#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_NO_APROVADO'),#(lf)#(tab)PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE'),#(lf)    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO'),#(lf)    PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'),#(lf)    (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'MONTO_APROVADO') - (PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'DEDUCIBLE') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COASEGURO') + PKG_CLAIM.GET_AMOUNT_BY_PAYING(cp2.ID_PAYING, 'COPAGO'))),#(lf)    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'C'), 'SIN PROVEEDOR'),#(lf)    NVL(GEN_SUPPLIER_NAME2_FUNC(cpd.ID_SUPPLIER, 'R'), 'SIN PROVEEDOR')#(lf)ORDER BY 1 DESC"])
				in
				    Origen

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

