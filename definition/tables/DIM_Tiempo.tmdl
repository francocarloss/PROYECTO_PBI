		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition DIM_Tiempo = calculated
		mode: import
		source =
				
				VAR MinDate = DATE( 2025, 1, 1 )
				VAR MaxDate = EOMONTH( TODAY(), 0 )
				RETURN
				ADDCOLUMNS(
				    CALENDAR( MinDate, MaxDate ),
				
				    -- ── Año / Mes / Día ───────────────────────────────
				    "Año",                  YEAR( [Date] ),
				    "Mes",                  MONTH( [Date] ),
				    "Nombre Mes",           FORMAT( [Date], "MMMM", "es-GT" ),
				    "Mes Corto",            FORMAT( [Date], "MMM", "es-GT" ),
				    "Año-Mes",              FORMAT( [Date], "YYYY-MM" ),
				    "Año-Mes Nombre",       FORMAT( [Date], "MMM YYYY", "es-GT" ),
				    "Día",                  DAY( [Date] ),
				    "Día Semana Num",       WEEKDAY( [Date], 2 ),
				    "Día Semana Nombre",    FORMAT( [Date], "dddd", "es-GT" ),
				    "Día Semana Corto",     FORMAT( [Date], "ddd", "es-GT" ),
				
				    -- ── Trimestre ─────────────────────────────────────
				    "Trimestre",            "Q" & FORMAT( [Date], "Q" ),
				    "Año-Trimestre",        FORMAT( [Date], "YYYY" ) & "-Q" & FORMAT( [Date], "Q" ),
				
				    -- ── Semana ────────────────────────────────────────
				    "Num Semana",           WEEKNUM( [Date], 2 ),
				
				    -- ── Flags útiles ──────────────────────────────────
				    "Es Fin de Semana",     IF( WEEKDAY( [Date], 2 ) >= 6, "Fin de semana", "Día hábil" ),
				    "Es Mes Actual",        IF( MONTH( [Date] ) = MONTH( TODAY() ) &&
				                                YEAR( [Date] )  = YEAR( TODAY() ),  "Mes actual", "Histórico" ),
				
				    -- ── Orden para ordenar visuales correctamente ─────
				    "Orden Mes",            YEAR( [Date] ) * 100 + MONTH( [Date] ),
				    "Orden Trimestre",      YEAR( [Date] ) * 10  + VALUE( FORMAT( [Date], "Q" ) )
				)

	annotation PBI_Id = 6e02b246d2c74bd1be9154c875676482

