				        "FECHA_FACTURA",              [FECHA_FACTURA],
				        "FECHA_INCURRIDO",            [FECHA_INCURRIDO],
				        "FECHA_LIQUIDACION",          [FECHA_LIQUIDACION],
				        "FECHA_RECEPCION",            [FECHA_RECEPCION],
				        "LIQUIDACION",                [LIQUIDACION],
