	partition FACT_Siniestros = calculated
		mode: import
		source =
				
				UNION (
				
				    -- ── CIRUGIAS ──────────────────────────────────────
				    SELECTCOLUMNS( Cirugias,
				        "TIPO_SERVICIO",              "CIRUGIA",
				        -- columnas compartidas
				        "ASEGURADO_TITULAR",          [ASEGURADO_TITULAR],
				        "ASEGURADORA",                [ASEGURADORA],
				        "CANTIDAD",                   [CANTIDAD],
				        "CERTIFICADO",                [CERTIFICADO],
				        "COBRO_ASEGURADORA",          [COBRO_ASEGURADORA],
				        "CODIGO_DIAGNOSTICO",         [CODIGO_DIAGNOSTICO],
				        "CONTRATANTE",                [CONTRATANTE],
				        "DIAGNOSTICO_SECUNDARIO",     [DIAGNOSTICO_SECUNDARIO],
				        "ESPECIALIDAD",               [ESPECIALIDAD],
				        "FECHA_AUTORIZACION",         [FECHA_AUTORIZACION],
				        "FECHA_FACTURA",              [FECHA_FACTURA],
				        "FECHA_INCURRIDO",            [FECHA_INCURRIDO],
				        "FECHA_LIQUIDACION",          [FECHA_LIQUIDACION],
				        "FECHA_RECEPCION",            [FECHA_RECEPCION],
				        "LIQUIDACION",                [LIQUIDACION],
				        "MEDICO_TRATANTE",            [MEDICO_TRATANTE],
				        "NOMBRE_DIAGNOSTICO_PRINCIPAL",[NOMBRE_DIAGNOSTICO_PRINCIPAL],
				        "NOMBRE_PACIENTE",            [NOMBRE_PACIENTE],
				        "NOMBRE_PROVEEDOR",           [NOMBRE_PROVEEDOR],
				        "NUMERO_AUTORIZACION",        [NUMERO_AUTORIZACION],
				        "NUMERO_CARNET",              [NUMERO_CARNET],
				        "NUMERO_FACTURA",             [NUMERO_FACTURA],
				        "NUMERO_VERIFICACION",        [NUMERO_VERIFICACION],
				        "ORDEN",                      [ORDEN],
				        "PARENTESCO",                 [PARENTESCO],
				        "POLIZA",                     [POLIZA],
				        "RAZON_SOCIAL",               [RAZON_SOCIAL],
				        "RECLAMO",                    [RECLAMO],
				        "TIPO_ORDEN",                 [TIPO_ORDEN],
				        "VALOR_APROVADO",             [VALOR_APROVADO],
				        "VALOR_COASEGURO",            [VALOR_COASEGURO],
				        "VALOR_COPAGO",               [VALOR_COPAGO],
				        "VALOR_DEDUCIBLE",            [VALOR_DEDUCIBLE],
				        "VALOR_NO_APROVADO",          [VALOR_NO_APROVADO],
				        -- columnas únicas de CIRUGIAS
				        "CODIGO_PROCEDIMIENTO",       [CODIGO_PROCEDIMIENTO],
				        "DESCRIPCION_PROCEDIMIENTO",  [DESCRIPCION_PROCEDIMIENTO],
				        "DIAS_HOSPITALIZACION",       [DIAS_HOSPITALIZACION],
				        "FECHA_EGRESO",               [FECHA_EGRESO],
				        "FECHA_INGRESO",              [FECHA_INGRESO],
				        "OBSERVACIONES",              [OBSERVACIONES],
				        -- columnas únicas de otras tablas → BLANK
				        "HOSPITAL",                   BLANK(),
				        "CODIGO_EXAMEN",              BLANK(),
				        "NOMBRE_EXAMEN",              BLANK(),
				        "NOMBRE_MEDICAMENTO",         BLANK()
				    ),
				
				    -- ── HOSPITAL ──────────────────────────────────────
				    SELECTCOLUMNS( Hospital,
				        "TIPO_SERVICIO",              "HOSPITAL",
				        "ASEGURADO_TITULAR",          [ASEGURADO_TITULAR],
				        "ASEGURADORA",                [ASEGURADORA],
				        "CANTIDAD",                   BLANK(),
				        "CERTIFICADO",                [CERTIFICADO],
				        "COBRO_ASEGURADORA",          [COBRO_ASEGURADORA],
				        "CODIGO_DIAGNOSTICO",         [CODIGO_DIAGNOSTICO],
				        "CONTRATANTE",                [CONTRATANTE],
				        "DIAGNOSTICO_SECUNDARIO",     [DIAGNOSTICO_SECUNDARIO],
				        "ESPECIALIDAD",               BLANK(),
				        "FECHA_AUTORIZACION",         [FECHA_AUTORIZACION],
				        "FECHA_FACTURA",              [FECHA_FACTURA],
				        "FECHA_INCURRIDO",            [FECHA_INCURRIDO],
				        "FECHA_LIQUIDACION",          [FECHA_LIQUIDACION],
				        "FECHA_RECEPCION",            [FECHA_RECEPCION],
				        "LIQUIDACION",                [LIQUIDACION],
				        "MEDICO_TRATANTE",            BLANK(),
				        "NOMBRE_DIAGNOSTICO_PRINCIPAL",[NOMBRE_DIAGNOSTICO_PRINCIPAL],
				        "NOMBRE_PACIENTE",            [NOMBRE_PACIENTE],
				        "NOMBRE_PROVEEDOR",           [NOMBRE_PROVEEDOR],
				        "NUMERO_AUTORIZACION",        [NUMERO_AUTORIZACION],
				        "NUMERO_CARNET",              [NUMERO_CARNET],
				        "NUMERO_FACTURA",             [NUMERO_FACTURA],
				        "NUMERO_VERIFICACION",        BLANK(),
				        "ORDEN",                      BLANK(),
				        "PARENTESCO",                 [PARENTESCO],
				        "POLIZA",                     [POLIZA],
				        "RAZON_SOCIAL",               [RAZON_SOCIAL],
				        "RECLAMO",                    [RECLAMO],
				        "TIPO_ORDEN",                 [TIPO_ORDEN],
				        "VALOR_APROVADO",             [VALOR_APROVADO],
				        "VALOR_COASEGURO",            [VALOR_COASEGURO],
				        "VALOR_COPAGO",               [VALOR_COPAGO],
				        "VALOR_DEDUCIBLE",            [VALOR_DEDUCIBLE],
				        "VALOR_NO_APROVADO",          [VALOR_NO_APROVADO],
				        "CODIGO_PROCEDIMIENTO",       BLANK(),
				        "DESCRIPCION_PROCEDIMIENTO",  BLANK(),
				        "DIAS_HOSPITALIZACION",       [DIAS_HOSPITALIZACION],
				        "FECHA_EGRESO",               [FECHA_EGRESO],
				        "FECHA_INGRESO",              [FECHA_INGRESO],
				        "OBSERVACIONES",              [OBSERVACIONES],
				        "HOSPITAL",                   [HOSPITAL],
				        "CODIGO_EXAMEN",              BLANK(),
				        "NOMBRE_EXAMEN",              BLANK(),
				        "NOMBRE_MEDICAMENTO",         BLANK()
				    ),
				
				    -- ── LABORATORIOS ──────────────────────────────────
				    SELECTCOLUMNS( Laboratorios,
				        "TIPO_SERVICIO",              "LABORATORIO",
				        "ASEGURADO_TITULAR",          [ASEGURADO_TITULAR],
				        "ASEGURADORA",                [ASEGURADORA],
				        "CANTIDAD",                   [CANTIDAD],
				        "CERTIFICADO",                [CERTIFICADO],
				        "COBRO_ASEGURADORA",          [COBRO_ASEGURADORA],
				        "CODIGO_DIAGNOSTICO",         [CODIGO_DIAGNOSTICO],
				        "CONTRATANTE",                [CONTRATANTE],
				        "DIAGNOSTICO_SECUNDARIO",     [DIAGNOSTICO_SECUNDARIO],
				        "ESPECIALIDAD",               [ESPECIALIDAD],
				        "FECHA_AUTORIZACION",         [FECHA_AUTORIZACION],
				        "FECHA_FACTURA",              [FECHA_FACTURA],
				        "FECHA_INCURRIDO",            [FECHA_INCURRIDO],
				        "FECHA_LIQUIDACION",          [FECHA_LIQUIDACION],
				        "FECHA_RECEPCION",            [FECHA_RECEPCION],
				        "LIQUIDACION",                [LIQUIDACION],
				        "MEDICO_TRATANTE",            [MEDICO_TRATANTE],
				        "NOMBRE_DIAGNOSTICO_PRINCIPAL",[NOMBRE_DIAGNOSTICO_PRINCIPAL],
				        "NOMBRE_PACIENTE",            [NOMBRE_PACIENTE],
				        "NOMBRE_PROVEEDOR",           [NOMBRE_PROVEEDOR],
				        "NUMERO_AUTORIZACION",        [NUMERO_AUTORIZACION],
				        "NUMERO_CARNET",              [NUMERO_CARNET],
				        "NUMERO_FACTURA",             [NUMERO_FACTURA],
				        "NUMERO_VERIFICACION",        [NUMERO_VERIFICACION],
				        "ORDEN",                      [ORDEN],
				        "PARENTESCO",                 [PARENTESCO],
				        "POLIZA",                     [POLIZA],
				        "RAZON_SOCIAL",               [RAZON_SOCIAL],
				        "RECLAMO",                    [RECLAMO],
				        "TIPO_ORDEN",                 [TIPO_ORDEN],
				        "VALOR_APROVADO",             [VALOR_APROVADO],
				        "VALOR_COASEGURO",            [VALOR_COASEGURO],
				        "VALOR_COPAGO",               [VALOR_COPAGO],
				        "VALOR_DEDUCIBLE",            [VALOR_DEDUCIBLE],
				        "VALOR_NO_APROVADO",          BLANK(),
				        "CODIGO_PROCEDIMIENTO",       BLANK(),
				        "DESCRIPCION_PROCEDIMIENTO",  BLANK(),
				        "DIAS_HOSPITALIZACION",       BLANK(),
				        "FECHA_EGRESO",               BLANK(),
				        "FECHA_INGRESO",              BLANK(),
				        "OBSERVACIONES",              BLANK(),
				        "HOSPITAL",                   BLANK(),
				        "CODIGO_EXAMEN",              [CODIGO_EXAMEN],
				        "NOMBRE_EXAMEN",              [NOMBRE_EXAMEN],
				        "NOMBRE_MEDICAMENTO",         BLANK()
				    ),
				
				    -- ── PROCEDIMIENTOS ────────────────────────────────
				    SELECTCOLUMNS( Procedimientos,
				        "TIPO_SERVICIO",              "PROCEDIMIENTO",
				        "ASEGURADO_TITULAR",          [ASEGURADO_TITULAR],
				        "ASEGURADORA",                [ASEGURADORA],
